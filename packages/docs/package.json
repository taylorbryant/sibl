{
  "name": "@sibl/docs",
  "version": "0.3.0",
  "description": "Explicit, Next-native documentation primitives for people and agents.",
  "author": "Taylor Bryant",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/taylorbryant/sibl#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taylorbryant/sibl.git",
    "directory": "packages/docs"
  },
  "bugs": {
    "url": "https://github.com/taylorbryant/sibl/issues"
  },
  "keywords": [
    "documentation",
    "docs",
    "mdx",
    "nextjs",
    "react",
    "llms.txt"
  ],
  "engines": {
    "node": ">=20.9.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "default": "./dist/server.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "default": "./dist/react.js"
    },
    "./mdx": {
      "types": "./dist/mdx.d.ts",
      "import": "./dist/mdx.js",
      "default": "./dist/mdx.js"
    },
    "./mdx-config": {
      "types": "./dist/mdx-config.d.ts",
      "import": "./dist/mdx-config.js",
      "default": "./dist/mdx-config.js"
    },
    "./rehype-shiki": {
      "import": "./dist/rehype-shiki.js",
      "default": "./dist/rehype-shiki.js"
    },
    "./rehype-slug": {
      "import": "./dist/rehype-slug.js",
      "default": "./dist/rehype-slug.js"
    },
    "./remark-gfm": {
      "import": "./dist/remark-gfm.js",
      "default": "./dist/remark-gfm.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && cp src/styles.css dist/styles.css",
    "prepublishOnly": "bun run build && bun run typecheck && bun test",
    "test": "bun test",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@shikijs/rehype": "^4.0.2",
    "@types/mdx": "^2.0.13",
    "github-slugger": "^2.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@mdx-js/loader": ">=3.0.0",
    "@mdx-js/react": ">=3.0.0",
    "@next/mdx": ">=16.0.11",
    "next": ">=16.0.11",
    "react": ">=19.2.4",
    "react-dom": ">=19.2.4"
  },
  "devDependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.10",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
