{
  "name": "sibl-workspace",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:docs": "turbo run build --filter=@sibl/www",
    "build:package": "turbo run build --filter=@sibl/docs",
    "changeset": "changeset",
    "dev": "turbo run dev --filter=@sibl/www",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "release": "turbo run build typecheck test && changeset publish",
    "release:status": "changeset status --verbose",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "version-packages": "changeset version && bun install",
    "check": "biome check . && turbo run build typecheck test"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@changesets/cli": "^2.31.1",
    "@types/bun": "latest",
    "@types/node": "^26.1.1",
    "turbo": "^2.10.5",
    "typescript": "6.0.3"
  }
}
