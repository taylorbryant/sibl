{
  "name": "sibl-workspace",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:docs": "turbo run build --filter=@sibl/site",
    "build:package": "turbo run build --filter=@sibl/docs",
    "dev": "turbo run dev --filter=@sibl/site",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "check": "turbo run build typecheck test"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^26.1.1",
    "turbo": "^2.10.5",
    "typescript": "6.0.3"
  }
}
